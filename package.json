{
  "name": "modelizer",
  "private": true,
  "version": "0.9.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && rimraf bundle/app/dist && cpy \"dist/**\" bundle/app/dist --parents",
    "build:ci": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run lint && npm run test:unit",
